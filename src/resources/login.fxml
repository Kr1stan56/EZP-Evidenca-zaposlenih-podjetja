<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.LoginController"
            prefWidth="300" prefHeight="200">

    <TextField fx:id="usernameField" layoutX="50" layoutY="50" promptText="Username"/>
    <TextField fx:id="passwordField" layoutX="50" layoutY="90" promptText="Password"/>
    <Button fx:id="loginButton" layoutX="100" layoutY="140" text="Login"/>

</AnchorPane>
